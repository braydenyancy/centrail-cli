{
  "name": "centrail",
  "version": "0.5.0",
  "description": "Sync your local AI coding-agent usage (Claude Code, GitHub Copilot CLI, Codex) to centrail.org.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": { "centrail": "./dist/index.js" },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --alias:@centrail/parsers=../parsers/src/index.ts --outfile=dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@centrail/parsers": "*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.19.12",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
